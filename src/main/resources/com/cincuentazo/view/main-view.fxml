<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cincuentazo.controller.MainController" styleClass="root">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="Cincuentazo" styleClass="title"/>
            <HBox spacing="10">
                <Label text="Jugadores maquina:"/>
                <ComboBox fx:id="machineCountCombo" prefWidth="120"/>
                <Button fx:id="startButton" text="Iniciar juego"/>
                <Label text="Suma mesa:" styleClass="meta-label"/>
                <Label fx:id="tableSumLabel" text="0" styleClass="meta-value"/>
                <Label text="Carta superior:" styleClass="meta-label"/>
                <Label fx:id="topCardLabel" text="-" styleClass="meta-value"/>
                <Label text="Mazo:" styleClass="meta-label"/>
                <Label fx:id="deckCountLabel" text="0" styleClass="meta-value"/>
                <Label text="Turno:" styleClass="meta-label"/>
                <Label fx:id="currentTurnLabel" text="-" styleClass="meta-value"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" styleClass="center-panel">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <VBox spacing="10" prefWidth="350" styleClass="panel">
                <Label text="Jugadores maquina" styleClass="section-title"/>
                <VBox fx:id="machinePlayersBox" spacing="8"/>
            </VBox>

            <VBox spacing="10" prefWidth="420" styleClass="panel">
                <Label text="Mano humana (clic o tecla 1-4)" styleClass="section-title"/>
                <HBox fx:id="humanCardsBox" spacing="8"/>

                <HBox spacing="12">
                    <Label text="Operacion:"/>
                    <RadioButton fx:id="addRadio" text="+"/>
                    <RadioButton fx:id="subtractRadio" text="-"/>
                    <Button fx:id="playButton" text="Jugar carta seleccionada"/>
                </HBox>

                <Label text="Teclado: 1-4 seleccion, +/- operacion, Enter/Espacio jugar" styleClass="help"/>
                <Label fx:id="statusLabel" text="Estado" wrapText="true" styleClass="status"/>
            </VBox>

            <VBox spacing="10" prefWidth="300" styleClass="panel">
                <Label text="Historial" styleClass="section-title"/>
                <ListView fx:id="historyList" prefHeight="420"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
